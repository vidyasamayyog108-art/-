rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth-based helpers
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // --- User Profiles ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'phoneNumber', 'fullName', 'subCaste', 'birthDate', 'birthTime', 'birthPlace', 'gender'])
          && data.uid == request.auth.uid
          && data.fullName is string && data.fullName.size() <= 100
          && data.subCaste is string && data.subCaste.size() <= 50
          && data.phoneNumber is string && data.phoneNumber.size() <= 15;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || resource.data.status == 'approved');
      allow create: if isSignedIn() && isValidUser(incoming()) && incoming().status == 'pending' && incoming().isPremium == false;
      allow update: if isSignedIn() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'subCaste', 'gotra', 'birthDate', 'birthTime', 'birthPlace', 'profilePhotoUrl'])) ||
        isAdmin()
      );
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }

    // --- Messages ---
    match /chats/{chatId}/messages/{messageId} {
      // chatId usually formats as uid1_uid2
      function isParticipant() {
        let uids = chatId.split('_');
        return isSignedIn() && (request.auth.uid == uids[0] || request.auth.uid == uids[1]);
      }
      function isPremium() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremium == true;
      }

      allow read: if isParticipant();
      allow create: if isParticipant() && isPremium() && incoming().senderId == request.auth.uid;
    }

    // --- Ads ---
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
      // Allow incrementing clicks/views for anyone
      allow update: if incoming().diff(existing()).affectedKeys().hasOnly(['views', 'clicks']);
    }

    // --- Success Stories ---
    match /successStories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Settings ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Admins collection (initially empty or manual entry) ---
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
